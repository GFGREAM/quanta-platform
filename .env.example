# Power BI Service Principal
POWERBI_TENANT_ID=your-tenant-id-here
POWERBI_CLIENT_ID=your-client-id-here
POWERBI_CLIENT_SECRET=your-client-secret-here
POWERBI_WORKSPACE_ID=your-workspace-id-here
POWERBI_DATASET_ID=your-dataset-id-here
NEXT_PUBLIC_POWERBI_WORKSPACE_ID=your-dashboard-workspace-id-here
NEXT_PUBLIC_POWERBI_REPORT_ID=your-dashboard-report-id-here
NEXT_PUBLIC_POWERBI_SATISFACTION_REPORT_ID=your-satisfaction-report-id-here
NEXT_PUBLIC_POWERBI_SATISFACTION_WORKSPACE_ID=your-satisfaction-workspace-id-here
NEXT_PUBLIC_POWERBI_META_REPORT_ID=your-meta-positioning-report-id-here

# NextAuth.js + Azure AD Authentication
AUTH_AZURE_AD_CLIENT_ID=your-azure-ad-app-client-id
AUTH_AZURE_AD_TENANT_ID=your-azure-ad-tenant-id
AUTH_AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://quanta.gfgam.com

# Postgres (Azure Flexible Server)
DATABASE_URL=postgres://user:password@gfg-postgresql-server-2025.postgres.database.azure.com:5432/gfg_asset_management?sslmode=require&application_name=quanta-aag
